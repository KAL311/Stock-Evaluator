# Secrets
FMP_API.env
*.env
!*.env.example

# Python
__pycache__/
*.pyc
*.pyo

# Large data / caches (not source of truth for the experiment)
*.db
data/simfin/
data/*.db
data/*.log
ruvector.db

# Audit CSVs are regenerable from a locked run; JSONs remain tracked
# as the primary run-metadata record.
data/audit/*.csv

# FMP listing oracle cache (regenerable via scripts/fetch_fmp_listing_status.py)
data/fmp/

# Rendered HTML reports (regenerable via scripts/generate_html_report.py)
reports/*.html

# Local archive of stray outputs / session captures
archive/

# Backups
*.bak

# Raw run outputs / dumps
*.output
*_output.txt
*.zip
*.jsonl

# Session scratch files (audit intermediates, diff snapshots)
/.scratch_*
data/stock_cache.db.audit_backup
data/stock_cache.db.*_backup

# Botched-redirect 0-byte junk fragments in repo root
# Root cause: Python code with `>=`, `>`, `<`, or `{var}` embedded in a Bash
# command without single-quoting or heredoc. The shell parses the operator
# as a file redirect, creating an empty file. Fix is discipline
# (always wrap Python in `python << 'PYEOF' ... PYEOF` or single quotes),
# but keep these patterns as a defensive fallback so a slip does not
# pollute the tree.
/+*
/(*
/0)
/float
/threshold,+
/${MIN_MARKET_CAP
/MIN_MARKET_CAP*
/large_thresh
/val],
/500%
/60
/72s}'),
/24h)
/2.6
/20
/{batch_ok*
/{insider_own*
/{*}
# Broad shape-based catches. Root-only — do not accidentally shadow files
# in real subdirectories.
/*].index.tolist*
/*.tolist*
/*),+

reports/.last_top10.json
reports/archive/
